Algoritmo segundoejercicio
	
	definir arreglo como real
	definir i,X, n como real
	definir mayor, menor como real
	
	n <- 15
	
	dimension arreglo[n]
	
	Para i<-0 Hasta n-1 Con Paso 1 Hacer
		arreglo[i] <- azar(100)
		Escribir arreglo[i]
	Fin Para
	
	mayor <- arreglo [0]
	menor <- arreglo [0]
	
	Para i<-1 Hasta n-1 Con Paso 1 Hacer
		
		Si arreglo[i] > mayor Entonces
			mayor <- arreglo [i]
		Fin Si

		Si arreglo[i] < menor entonces			
			menor <- arreglo[i]
		FinSi
		
	Fin Para
	
	Escribir "El número más grande de este grupo es ", mayor;
	Escribir "El número más chico de este grupo es ", menor;
	
FinAlgoritmo
